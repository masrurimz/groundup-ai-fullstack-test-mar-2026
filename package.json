{
  "name": "groundup-ai-fullstack-test-mar-2026",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "alchemy": "^0.82.1"
    }
  },
  "type": "module",
  "scripts": {
    "env:run": "infisical run --domain https://infisical.zahid.es/api --env dev --",
    "env:use": "bun scripts/env-switch.ts",
    "dev": "bun run env:run turbo dev",
    "build": "turbo build",
    "generate:client": "bash scripts/generate-client.sh",
    "verify:generated:client": "bash scripts/generate-client.sh && git diff --exit-code -- apps/web/src/lib/api-client",
    "check:types": "turbo check:types",
    "check:lint": "turbo check:lint",
    "dev:server": "bun run env:run turbo -F server dev",
    "dev:web": "bun run env:run turbo -F web dev",
    "db:migrate": "bun run env:run bun run -F server db:migrate",
    "seed": "bun run env:run bun run -F server seed",
    "seed:dev": "bun run env:run bun run -F server seed:dev",
    "deploy": "bun run env:run turbo -F @groundup-ai-fullstack-test-mar-2026/infra deploy",
    "destroy": "bun run env:run turbo -F @groundup-ai-fullstack-test-mar-2026/infra destroy",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@groundup-ai-fullstack-test-mar-2026/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251213.0",
    "@groundup-ai-fullstack-test-mar-2026/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.9"
}
